# ─────────────────────────────────────────────
# Keycloak-Datenbank
# ─────────────────────────────────────────────
KC_DB_NAME=keycloak
KC_DB_USER=keycloak
KC_DB_PASSWORD=change-me
KC_DB_PORT=5433

# ─────────────────────────────────────────────
# Applikations-Datenbank (PostgreSQL)
# ─────────────────────────────────────────────
APP_DB_NAME=cookieclicker
APP_DB_USER=postgres
APP_DB_PASSWORD=change-me
APP_DB_PORT=5434

# ─────────────────────────────────────────────
# Keycloak
# ─────────────────────────────────────────────
# Nur für Docker Compose (Keycloak-Init) – nicht mehr von Spring-Services verwendet
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change-me
KEYCLOAK_PORT=8180
KEYCLOAK_REALM=cookieclicker
KEYCLOAK_CLIENT_ID=cookieclicker-client
KEYCLOAK_CLIENT_SECRET=change-me

# ─────────────────────────────────────────────
# Service-URLs (lokale Entwicklung)
# ─────────────────────────────────────────────
KEYCLOAK_URL=http://localhost:8180
AUTH_SERVICE_URL=http://localhost:8081
PERSISTENCE_SERVICE_URL=http://localhost:8082
